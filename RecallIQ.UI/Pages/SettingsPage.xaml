<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="RecallIQ.UI.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    NavigationCacheMode="Enabled">

    <ScrollViewer Padding="32">
        <StackPanel Spacing="24" MaxWidth="800">
            <TextBlock Text="Settings" Style="{StaticResource TitleTextBlockStyle}"/>

            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="20">
                <StackPanel Spacing="16">
                    <TextBlock Text="Watched Folders" Style="{StaticResource SubtitleTextBlockStyle}"/>

                    <ListView ItemsSource="{x:Bind ViewModel.WatchedFolders, Mode=OneWay}"
                              SelectionChanged="FolderList_SelectionChanged"
                              SelectionMode="Single" MaxHeight="200">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="x:String">
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <FontIcon Grid.Column="0" Glyph="&#xE838;" FontSize="16"/>
                                    <TextBlock Grid.Column="1" Text="{x:Bind}" TextTrimming="CharacterEllipsis"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="Add Folder" Click="AddFolder_Click"/>
                        <Button Content="Remove Selected"
                                Command="{x:Bind ViewModel.RemoveFolderCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="20">
                <StackPanel Spacing="16">
                    <TextBlock Text="Indexing" Style="{StaticResource SubtitleTextBlockStyle}"/>

                    <ToggleSwitch Header="Enable Indexing"
                                  IsOn="{x:Bind ViewModel.IsIndexingEnabled, Mode=TwoWay}"/>

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="Rebuild Index"
                                Command="{x:Bind ViewModel.RebuildIndexCommand}"/>
                        <Button Content="Pause/Resume"
                                Command="{x:Bind ViewModel.PauseIndexingCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="20">
                <StackPanel Spacing="16">
                    <TextBlock Text="AI Model" Style="{StaticResource SubtitleTextBlockStyle}"/>
                    <TextBox Header="Model Path"
                             Text="{x:Bind ViewModel.AiModelPath, Mode=TwoWay}"/>
                    <NumberBox Header="Max Search Results"
                              Value="{x:Bind ViewModel.MaxSearchResults, Mode=TwoWay}"
                              Minimum="1" Maximum="100" SpinButtonPlacementMode="Inline"/>
                </StackPanel>
            </Border>

            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="20">
                <StackPanel Spacing="16">
                    <TextBlock Text="Appearance" Style="{StaticResource SubtitleTextBlockStyle}"/>
                    <ToggleSwitch Header="Dark Mode"
                                  IsOn="{x:Bind ViewModel.IsDarkMode, Mode=TwoWay}"
                                  Toggled="DarkMode_Toggled"/>
                </StackPanel>
            </Border>

            <Button Content="Save Settings" Style="{StaticResource AccentButtonStyle}"
                    Command="{x:Bind ViewModel.SaveSettingsCommand}" HorizontalAlignment="Right"/>

            <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </StackPanel>
    </ScrollViewer>
</Page>
