<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="RecallIQ.UI.Pages.ActivityPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:RecallIQ.UI.Converters"
    NavigationCacheMode="Enabled">

    <Page.Resources>
        <converters:DateTimeConverter x:Key="DateTimeConverter"/>
    </Page.Resources>

    <Grid Padding="32" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Activity Log" Style="{StaticResource TitleTextBlockStyle}"/>

        <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.Activities, Mode=OneWay}"
                  SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid ColumnSpacing="16" Padding="8,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <FontIcon Grid.Column="0" Glyph="&#xE7BA;" FontSize="16"
                                  Foreground="{ThemeResource AccentFillColorDefaultBrush}"/>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="{Binding Message}" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding FilePath}" FontSize="11"
                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                       TextTrimming="CharacterEllipsis"
/>
                        </StackPanel>
                        <TextBlock Grid.Column="2" Text="{Binding TimestampUtc}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   FontSize="12" VerticalAlignment="Center"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
