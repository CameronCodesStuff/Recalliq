<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="RecallIQ.UI.Pages.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:RecallIQ.UI.Converters"
    NavigationCacheMode="Enabled">

    <Page.Resources>
        <converters:FileSizeConverter x:Key="FileSizeConverter"/>
        <converters:DateTimeConverter x:Key="DateTimeConverter"/>
    </Page.Resources>

    <ScrollViewer Padding="32">
        <StackPanel Spacing="24" MaxWidth="1200">
            <TextBlock Text="Dashboard" Style="{StaticResource TitleTextBlockStyle}"/>

            <Grid ColumnSpacing="16" RowSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8" Padding="20">
                    <StackPanel>
                        <FontIcon Glyph="&#xE8A5;" FontSize="28" Foreground="{ThemeResource AccentFillColorDefaultBrush}"/>
                        <TextBlock Text="{x:Bind ViewModel.TotalDocuments, Mode=OneWay}" Style="{StaticResource TitleTextBlockStyle}" Margin="0,8,0,0"/>
                        <TextBlock Text="Documents" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8" Padding="20">
                    <StackPanel>
                        <FontIcon Glyph="&#xE71E;" FontSize="28" Foreground="{ThemeResource AccentFillColorDefaultBrush}"/>
                        <TextBlock Text="{x:Bind ViewModel.TotalChunks, Mode=OneWay}" Style="{StaticResource TitleTextBlockStyle}" Margin="0,8,0,0"/>
                        <TextBlock Text="Chunks" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8" Padding="20">
                    <StackPanel>
                        <FontIcon Glyph="&#xE721;" FontSize="28" Foreground="{ThemeResource AccentFillColorDefaultBrush}"/>
                        <TextBlock Text="{x:Bind ViewModel.TotalSearches, Mode=OneWay}" Style="{StaticResource TitleTextBlockStyle}" Margin="0,8,0,0"/>
                        <TextBlock Text="Searches" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="3" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8" Padding="20">
                    <StackPanel>
                        <FontIcon Glyph="&#xEDA2;" FontSize="28" Foreground="{ThemeResource AccentFillColorDefaultBrush}"/>
                        <TextBlock Text="{x:Bind ViewModel.DatabaseSize, Mode=OneWay}" Style="{StaticResource TitleTextBlockStyle}" Margin="0,8,0,0"/>
                        <TextBlock Text="Database Size" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </Border>
            </Grid>

            <TextBlock Text="Recent Activity" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,16,0,0"/>
            <ListView ItemsSource="{x:Bind ViewModel.RecentActivity, Mode=OneWay}"
                      SelectionMode="None" MaxHeight="400">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid ColumnSpacing="12" Padding="4,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <FontIcon Grid.Column="0" Glyph="&#xE7BA;" FontSize="16"
                                      Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Grid.Column="1" Text="{Binding Message}"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Grid.Column="2" Text="{Binding TimestampUtc}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12"/>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </StackPanel>
    </ScrollViewer>
</Page>
